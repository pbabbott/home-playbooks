# Proxmox API (do not commit terraform.tfvars with real secrets)
proxmox_api_url          = "https://pve.example.com:8006/api2/json"
proxmox_api_token_id     = "user@pam!terraform"
proxmox_api_token_secret = "your-api-token-secret"

# Defaults for VMs
proxmox_node   = "chimaera"
template_name  = "ubuntu-cloud"
storage        = "local-lvm"
storage_ssd    = "longhorn-ssd"  # onboard SSD; pass as storage when VM should use it
bridge         = "vmbr0"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# VM ID convention: 900 = templates, 200 = production, 300 = non-prod, 500 = dev workstations
