# Proxmox API (do not commit terraform.tfvars with real secrets)
proxmox_api_url          = "https://pve.example.com:8006/api2/json"
proxmox_api_token_id     = "user@pam!terraform"
proxmox_api_token_secret = "your-api-token-secret"

# Defaults for VMs
proxmox_node   = "chimaera"
template_name  = "tf-template-ubuntu-noble"
storage        = "local-lvm"
storage_ssd    = "longhorn-ssd"  # onboard SSD; pass as storage when VM should use it
enable_nonprod_worker_ssd_data_disk = true
nonprod_worker_ssd_data_disk_size   = "256G"
bridge         = "vmbr0"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# VM ID convention: 900 = templates, 200 = production, 300 = non-prod, 500 = dev workstations

# Ubuntu cloud-init template build (Terraform-managed)
create_ubuntu_template       = true
ubuntu_template_name_prefix  = "tf-template-ubuntu"
ubuntu_template_primary_release = "noble"
ubuntu_template_vmids = {
  noble = 901
  # jammy = 902
}
ubuntu_template_storage      = "local-lvm"
ubuntu_template_disk_resize  = "+32G"
ubuntu_template_memory       = 6144
ubuntu_template_cores        = 4
ubuntu_template_bridge       = "vmbr0"
ubuntu_template_ipconfig0    = "ip=dhcp"
# ubuntu_template_ciuser         = "admin"
# ubuntu_template_cipassword     = "change-me"
# ubuntu_template_ssh_public_key_path_on_proxmox = "/root/.ssh/authorized_keys.pub"
# ubuntu_template_proxmox_ssh_host = "chimaera" # optional, defaults to proxmox_node
ubuntu_template_proxmox_ssh_user = "root"
ubuntu_template_proxmox_ssh_port = 22
